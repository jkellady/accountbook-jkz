# =============================================================================
# JK Zentra Finance Cockpit — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase — Required
# ---------------------------------------------------------------------------
# Your Supabase project URL (found in Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Your Supabase anon/public key (found in Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Your Supabase service role key — ONLY use server-side (found in Project Settings → API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# AI / OCR Extraction — Required for receipt/invoice parsing
# ---------------------------------------------------------------------------
# Google AI Studio API key for Gemini 2.5 Flash (primary extraction model)
GEMINI_API_KEY=your-gemini-api-key
# OpenAI API key for GPT-4o-mini fallback (optional but recommended)
OPENAI_API_KEY=your-openai-api-key

# ---------------------------------------------------------------------------
# Email — Required for reminder notifications
# ---------------------------------------------------------------------------
# Resend API key for transactional email delivery
RESEND_API_KEY=your-resend-api-key

# ---------------------------------------------------------------------------
# Google Calendar — Phase 2 (optional)
# ---------------------------------------------------------------------------
# Google OAuth 2.0 credentials for calendar integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Base URL of the deployed application (used for callbacks and links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
